# Local Docker example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Production/Preview example:
# Use the pooled PostgreSQL connection string from Vercel Postgres, Neon, Supabase,
# RDS Proxy, or another managed PostgreSQL provider.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require"

# Optional: direct PostgreSQL connection used by Prisma Migrate.
# For Supabase, prefer the direct connection string here and keep DATABASE_URL
# for the runtime pooler if needed.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Auth.js
AUTH_SECRET="replace-with-generated-secret"
# For Vercel, AUTH_URL is usually optional because Auth.js can infer the host.
# Set it explicitly if you use a custom domain or need a fixed canonical URL.
AUTH_URL="https://your-domain.example"
# Legacy/alias variable used by older NextAuth examples. Do not set this to a
# different value from AUTH_URL.
# NEXTAUTH_URL="https://your-domain.example"
# Usually inferred on Vercel. Set to "true" when self-hosting behind a proxy,
# including a future AWS load balancer/proxy setup if Auth.js cannot infer it.
# AUTH_TRUST_HOST="true"

# Single administrator credentials
ADMIN_USERNAME="USER"
ADMIN_PASSWORD="replace-with-strong-password"
